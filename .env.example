# Copia este archivo como ".env" y rellena UNA de las dos claves.
# NUNCA subas el archivo .env real a ningún lado ni lo compartas por chat.

# --- OPCIÓN A: Google Gemini (tiene capa gratuita) ---
# Consíguela en https://aistudio.google.com/apikey
GEMINI_API_KEY=
# (Opcional) Modelo de Gemini. Por defecto: gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# --- OPCIÓN B: Claude (Anthropic) ---
# Consíguela en https://console.anthropic.com  ->  API Keys
ANTHROPIC_API_KEY=
# (Opcional) Modelo de Claude. Por defecto: claude-opus-4-8
# CLAUDE_MODEL=claude-opus-4-8

# (Opcional) Forzar proveedor: "gemini" o "claude".
# Si no se fija, usa Gemini si hay GEMINI_API_KEY; si no, Claude.
# LLM_PROVIDER=gemini
